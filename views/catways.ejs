<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Créer une API pour le Port de Plaisance Russell</title>
</head>
<body>
    <header>
        <nav>
            <ul>
                <li><a href="/dashboard">Dashboard</a></li>
                <li><a href="/app/users">Utilisateur</a></li>
                <li><a href="/app/catways">Catways</a></li>
                <li><a href="/app/reservations">Réservation</a></li>
            </ul>
        </nav>
    </header>

    <main>
       <h2>Catways</h2>

<table border="1">
  <thead>
    <tr>
      <th>Voir le catway </th>
      <th>Numéro du catway</th>
      <th>Type de catway</th>
      <th>État du catway</th>
    </tr>
  </thead>
  <tbody>
    <% catways.forEach(catway => { %>
      <tr>
        <td><a href="/app/catways/<%= catway._id %>">Voir</a></td>
        <td><%= catway.catwayNumber %></td>
        <td><%= catway.catwayType %></td>
        <td><%= catway.catwayState %></td>
      </tr>
    <% }) %>
  </tbody>
</table>

<form action="/catways" method="POST">
    <div>
        <label for="catwayNumber">Numéro du catway</label>
        <input type="text" id="catwayNumber" name="catwayNumber" required>
    </div>

    <div>
        <label for="catwayType">Type de catway</label>
        <input type="text" id="catwayType" name="catwayType" required>
    </div>

    <div>
        <label for="catwayState">État du catway</label>
        <input type="text" id="catwayState" name="catwayState" required>
    </div>

    <button type="submit">Ajouter</button>
</form>

<br>
    </main>
    
</body>
</html>