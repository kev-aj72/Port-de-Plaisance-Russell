<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Créer une API pour le Port de Plaisance Russell</title>
</head>
<body>
    <header>
        <nav>
            <ul>
                <li><a href="/dashboard">Dashboard</a></li>
                <li><a href="/users">Utilisateur</a></li>
                <li><a href="/catways">Catways</a></li>
                <li><a href="/reservations">Réservation</a></li>
            </ul>
        </nav>
    </header>

    <main>
       
       <h2>Users</h2>

<table border="1">
  <thead>
    <tr>
      <th>Nom</th>
      <th>Email</th>
    </tr>
  </thead>
  <tbody>
    <% users.forEach(userItem => { %>
      <tr>
        <td><%= userItem.username %></td>
        <td><%= userItem.email %></td>
      </tr>
    <% }) %>
  </tbody>
</table>
       
    </main>
    
</body>
</html>