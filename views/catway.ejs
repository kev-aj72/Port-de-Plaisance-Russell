<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Détail du catway</title>
    <meta name="description" content="Gestion des catways et des réservations du port de plaisance Russell.">

     <link rel="icon" type="image.png" href="images/favicon.png">
     <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body>
    <header>
        <nav>
            <ul>
                <li><a href="/dashboard">Dashboard</a></li>
                <li><a href="/app/users">Utilisateur</a></li>
                <li><a href="/app/catways">Catways</a></li>
                <li><a href="/app/reservations">Réservation</a></li>
                <li><a href="/documentation">Documentation</a></li>
                <li><a href="/logout">Logout</a></li>
            </ul>
        </nav>
    </header>

    <main>
    <section>
        <h2>Détail du catway</h2>

            <!--tabeaux pour le catway-->
    <table>
        <thead>
            <tr>
                <th>Numéro</th>
                <th>Type</th>
                <th>État</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            <tr>
                <td>
                    <input type="text" id="catwayNumber" value="<%= catway.catwayNumber %>" readonly>
                </td>
                <td>
                    <input type="text" id="catwayType" value="<%= catway.catwayType %>" readonly>
                </td>
                <td>
                    <input type="text" id="catwayState" value="<%= catway.catwayState %>">
                </td>
                <td>
                    <button onclick="updateCatway('<%= catway.catwayNumber %>')">Modifier</button>
                    <button onclick="deleteCatway('<%= catway.catwayNumber %>')">Supprimer</button>
                </td>
            </tr>
        </tbody>
    </table>
    </section>


    <section>

        <h3>Réservations en cours</h3>

        <% if (reservations && reservations.length > 0) { %>
            <table>
                <thead> <!--tableaux reservation du catway-->
                    <tr>
                        <th>Client</th>
                        <th>Bateau</th>
                        <th>Date début</th>
                        <th>Date fin</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    <% reservations.forEach(reservation => { %>
                        <tr>
                            <td>
                                <input type="text" id="clientName-<%= reservation._id %>" value="<%= reservation.clientName %>">
                            </td>
                            <td>
                                <input type="text" id="boatName-<%= reservation._id %>" value="<%= reservation.boatName %>">
                            </td>
                            <td>
                                <input type="date" id="startDate-<%= reservation._id %>" value="<%= reservation.startDate ? new Date(reservation.startDate).toISOString().split('T')[0] : '' %>">
                            </td>
                            <td>
                                <input type="date" id="endDate-<%= reservation._id %>" value="<%= reservation.endDate ? new Date(reservation.endDate).toISOString().split('T')[0] : '' %>">
                            </td>
                            <td>
                                <button onclick="updateReservation('<%= reservation._id %>', '<%= catway.catwayNumber %>')"> Modifier </button>
                                <button onclick="deleteReservation('<%= reservation._id %>', '<%= catway.catwayNumber %>')"> Supprimer </button>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
                    <% } else { %><p>Aucune réservation pour ce catway.</p><% } %>
            </table>
    </section>

    <section>
        <h3>Ajouter une réservation</h3> <!--formulaire ajouter une reservation a ce catway-->

            <form action="/catways/<%= catway.catwayNumber %>/reservations" method="POST">

                <input type="text" name="clientName" placeholder="Nom du client" required>
                <input type="text" name="boatName" placeholder="Nom du bateau" required>
                <input type="date" name="startDate" required>
                <input type="date" name="endDate" required>

                <button type="submit">Ajouter</button>
            </form>

            <a class="back" href="/app/catways">Retour</a>
    </section>
    </main> 
    <footer>
        <small>© 2026 - Application Port de Plaisance Russell</small>
    </footer>
        <script src="/javascripts/catway.js"></script>
</body>
</html>